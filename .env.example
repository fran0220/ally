# ============================================================
# 基础设施（必填）
# ============================================================
HOST=0.0.0.0
PORT=43001
DATABASE_URL=mysql://root:password@127.0.0.1:23306/waoowaoo
REDIS_URL=redis://127.0.0.1:26379
JWT_SECRET=your-jwt-secret-at-least-32-chars-long
API_ENCRYPTION_KEY=change-this-to-a-strong-32-char-plus-secret
JWT_TTL_SECONDS=604800
CORS_ALLOW_ORIGIN=http://localhost:45173,http://185.200.65.233

# ============================================================
# 存储（二选一）
# ============================================================
# 本地存储
STORAGE_TYPE=local
UPLOAD_DIR=./uploads
NEXTAUTH_URL=http://localhost:43001

# 腾讯云 COS（生产环境）
# STORAGE_TYPE=cos
# COS_SECRET_ID=your-secret-id
# COS_SECRET_KEY=your-secret-key
# COS_BUCKET=your-bucket
# COS_REGION=ap-guangzhou
# COS_PUBLIC_BASE_URL=https://your-bucket.cos.ap-guangzhou.myqcloud.com
# COS_S3_ENDPOINT=https://your-bucket.cos.ap-guangzhou.myqcloud.com

# ============================================================
# Worker 队列并发（可选，有默认值）
# ============================================================
# QUEUE_CONCURRENCY_IMAGE=20
# QUEUE_CONCURRENCY_TEXT=10
# QUEUE_CONCURRENCY_VIDEO=4
# QUEUE_CONCURRENCY_VOICE=10

# ============================================================
# 内部任务令牌（可选）
# ============================================================
INTERNAL_TASK_TOKEN=

# ============================================================
# 计费模式（可选）
# OFF: 不计费；SHADOW: 只记录不冻结；ENFORCE: 冻结并扣费
# ============================================================
BILLING_MODE=OFF

# ============================================================
# 多厂商生成器 API（可选，优先使用数据库中的 provider 配置）
# ============================================================
ARK_API_KEY=
GOOGLE_AI_KEY=
MINIMAX_API_KEY=
VIDU_API_KEY=

# ============================================================
# 多厂商生成器 Endpoint（可选）
# ============================================================
ARK_API_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
GOOGLE_API_BASE_URL=https://generativelanguage.googleapis.com
MINIMAX_API_BASE_URL=https://api.minimaxi.com/v1
VIDU_API_BASE_URL=https://api.vidu.cn/ent/v2

# ============================================================
# 生成器重试 / 轮询（可选）
# ============================================================
GENERATOR_HTTP_TIMEOUT_SECS=120
LLM_STREAM_CHUNK_TIMEOUT_MS=180000
GENERATOR_POLL_INTERVAL_MS=3000
GENERATOR_POLL_TIMEOUT_SECS=1200
GENERATOR_RETRY_MAX_ATTEMPTS=3
GENERATOR_RETRY_BACKOFF_MS=1000
