# ============================================================
# 基础设施（必填）
# ============================================================
HOST=0.0.0.0
PORT=3001
DATABASE_URL=mysql://root:password@127.0.0.1:3306/waoowaoo
REDIS_URL=redis://127.0.0.1:6379
JWT_SECRET=your-jwt-secret-at-least-32-chars-long
JWT_TTL_SECONDS=604800
CORS_ALLOW_ORIGIN=http://localhost:5173,http://localhost:3000

# ============================================================
# 存储（二选一）
# ============================================================
# 本地存储
STORAGE_TYPE=local
UPLOAD_DIR=./uploads
NEXTAUTH_URL=http://localhost:3001

# 腾讯云 COS（生产环境）
# STORAGE_TYPE=cos
# COS_BUCKET=your-bucket
# COS_REGION=ap-guangzhou
# COS_PUBLIC_BASE_URL=https://your-bucket.cos.ap-guangzhou.myqcloud.com

# ============================================================
# Worker 队列并发（可选，有默认值）
# ============================================================
# QUEUE_CONCURRENCY_IMAGE=20
# QUEUE_CONCURRENCY_TEXT=10
# QUEUE_CONCURRENCY_VIDEO=4
# QUEUE_CONCURRENCY_VOICE=10

# ============================================================
# 内部任务令牌（可选）
# ============================================================
INTERNAL_TASK_TOKEN=
